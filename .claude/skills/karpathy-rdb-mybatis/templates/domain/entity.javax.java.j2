    private {{ f.java_type }} {{ f.field }};
{%- else %}
    {% if f.is_pk %}@Id
    {% endif %}@Column(name = "{{ f.column }}")
    private {{ f.java_type }} {{ f.field }};
{%- endif %}
{% endfor %}

{% for f in fields %}
    public {{ f.java_type }} {{ f.getter }}() { return {{ f.field }}; }
